Host *
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519

# BEGIN pig-managed hosts
Host resource_intensive_vm
    HostName dev-resourceintensive-host
    User <YOUR_EMAIL>
    SetEnv AZ_SSH_RG=dev-rg

Host macro_vm
    HostName dev-macro-host
    User <YOUR_EMAIL>
    SetEnv AZ_SSH_RG=dev-rg

# END pig-managed hosts
