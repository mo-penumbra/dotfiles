#!/usr/bin/env bash
set -euo pipefail

SINCE="${1:-1 year ago}"

header() { printf '\n\033[1;36m── %s ──\033[0m\n' "$1"; }

git rev-parse --git-dir >/dev/null 2>&1 || { echo "Not a git repo"; exit 1; }

header "Most-changed files (since $SINCE)"
git log --format=format: --name-only --since="$SINCE" \
  | sort | uniq -c | sort -nr | head -20

header "Top contributors (all time)"
git shortlog -sn --no-merges

header "Active contributors (since $SINCE)"
git shortlog -sn --no-merges --since="$SINCE"

header "Bug hotspots (since $SINCE)"
git log -i -E --grep="fix|bug|broken" --name-only --format='' --since="$SINCE" \
  | sort | uniq -c | sort -nr | head -20

header "Commit velocity (by month)"
git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c

header "Firefighting (since $SINCE)"
git log --oneline --since="$SINCE" | grep -iE 'revert|hotfix|emergency|rollback' || echo "  None found"
